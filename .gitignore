# Entornos virtuales
.venv/
venv/
ENV/

# Caches de Python
__pycache__/
*.py[cod]
*$py.class

# Datos historicos pesados del panel de backtesting.
# Se mantiene el .gitkeep para conservar la estructura de carpeta.
PANEL BACKTESTING/HISTORICO/*
!PANEL BACKTESTING/HISTORICO/.gitkeep

# Resultados generados por ejecuciones locales.
PANEL BACKTESTING/RESULTADOS/*
!PANEL BACKTESTING/RESULTADOS/.gitkeep

# ZIPs y CSVs temporales del descargador (se regeneran en cada ejecución).
DESCARGADOR/tmp/

# Artefactos generados por Cargo/Rust.
PANEL BACKTESTING/MOTOR/target/

# Carpeta temporal usada solo como referencia local
github TEMPORAL/
github temporal/

# Archivos del sistema/editor
.DS_Store
.idea/
.vscode/
